{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "Vite dev server",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev"],
      "port": 5173,
      "autoPort": true
    },
    {
      "name": "Vite preview (production build)",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "preview"],
      "port": 4173,
      "autoPort": true
    },
    {
      "name": "Firebase emulators",
      "runtimeExecutable": "firebase",
      "runtimeArgs": ["emulators:start", "--project", "demo-hostelhub"],
      "port": 4000,
      "autoPort": false
    }
  ]
}
