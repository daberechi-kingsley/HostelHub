# Firebase Web SDK config — copy to .env.local and fill in real values
# Get these from: Firebase Console → Project Settings → Your apps → Web app
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_DATABASE_URL=

# Use Firebase emulators during local dev. Set to "true" to route SDK calls to localhost.
VITE_USE_EMULATORS=true

# FCM Web Push VAPID key — Firebase Console → Project Settings → Cloud Messaging
# → Web configuration → Generate key pair. Leave blank to disable push (emulator dev).
VITE_FCM_VAPID_KEY=

# Hidden admin bootstrap account (entered via the "Sign in with email" option).
# ⚠️ NOT SECRET — VITE_* vars are bundled into client JS and readable by anyone.
# The real admin gate is the email-matched Firebase Auth token in firestore.rules.
# VITE_ADMIN_EMAIL must match ADMIN_EMAILS (src/config/constants.ts) and the rules.
# Requires the Email/Password provider enabled in Firebase Auth.
# IMPORTANT: wrap the password in double quotes if it contains '#' (or other
# special chars) — Vite's dotenv parser treats an unquoted '#' as an inline
# comment and silently truncates the value there. e.g. VITE_ADMIN_PASSWORD="p#ss"
VITE_ADMIN_EMAIL=
VITE_ADMIN_PASSWORD=
